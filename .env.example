# ──────────────────────────────────────────────────────────────
# GlucoTrack Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# Supabase — https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Groq — CGM doktor raporu özelliği (https://console.groq.com/keys)
VITE_GROQ_API_KEY=

# Stripe — used only in the Supabase Edge Function (not the frontend)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...         # Monthly subscription price ID
